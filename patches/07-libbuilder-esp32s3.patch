diff --git a/CMakeLists.txt b/CMakeLists.txt
index 3b42dec..7dc8c0b 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -40,3 +40,7 @@ idf_build_set_property(COMPILE_DEFINITIONS "-DESP32_ARDUINO_LIB_BUILDER" APPEND)
 ### ESP Matter ###
 ##################
 idf_build_set_property(CXX_COMPILE_OPTIONS "-std=gnu++2a;-DCHIP_HAVE_CONFIG_H" APPEND)
+# GCC false positives in managed components (connectedhomeip's CHIPMemString.h,
+# esp-modbus' port_tcp_utils.c). The components are re-downloaded on every dependency
+# re-solve, so they cannot be patched in place. Applies to both C and C++.
+idf_build_set_property(COMPILE_OPTIONS "-Wno-error=stringop-truncation;-Wno-error=stringop-overread;-Werror=maybe-uninitialized" APPEND)
diff --git a/build.sh b/build.sh
index 9810f4f..3d7d460 100755
--- a/build.sh
+++ b/build.sh
@@ -16,7 +16,9 @@ if ! [ -x "$(command -v ninja)" ]; then
 fi
 
 # Fixes building some components. See https://github.com/espressif/arduino-esp32/issues/10167
-export IDF_COMPONENT_OVERWRITE_MANAGED_COMPONENTS=1
+# Disabled: it re-downloads managed components on every configure, reverting the local
+# stringop-truncation patch in espressif__esp_matter (CHIPMemString.h).
+export IDF_COMPONENT_OVERWRITE_MANAGED_COMPONENTS=0
 
 CCACHE_ENABLE=1
 
