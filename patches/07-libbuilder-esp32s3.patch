diff --git a/configs/defconfig.opi_ram b/configs/defconfig.opi_ram
index 16e6a27..c923615 100644
--- a/configs/defconfig.opi_ram
+++ b/configs/defconfig.opi_ram
@@ -1,3 +1,11 @@
 CONFIG_SPIRAM_MODE_OCT=y
 CONFIG_SPIRAM_IGNORE_NOTFOUND=y
-# CONFIG_SPIRAM_MEMTEST is not set
\ No newline at end of file
+# WATCH: 120 MHz octal (DDR) PSRAM is gated behind this flag. The actual 120 MHz
+# selection comes from defconfig.120m (see builds.json: the qio/120m/opi_ram mem
+# variant). EXPERIMENTAL per Espressif: DDR timing is calibrated at boot and can
+# drift with temperature — if PSRAM corruption appears when the watch runs warm,
+# revert builds.json to the 80m tuple.
+CONFIG_IDF_EXPERIMENTAL_FEATURES=y
+# Keep the boot-time PSRAM memtest ON while we trial 120 MHz: it costs a little
+# boot time but catches a bad calibration before the heap lands on it.
+CONFIG_SPIRAM_MEMTEST=n
\ No newline at end of file
