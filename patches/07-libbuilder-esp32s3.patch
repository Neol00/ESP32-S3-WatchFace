diff --git a/configs/defconfig.esp32s3 b/configs/defconfig.esp32s3
index e11993c..6f4369a 100644
--- a/configs/defconfig.esp32s3
+++ b/configs/defconfig.esp32s3
@@ -5,9 +5,22 @@ CONFIG_BTDM_CTRL_MODE_BTDM=n
 CONFIG_BT_BLUEDROID_ENABLED=n
 CONFIG_BT_NIMBLE_ENABLED=y
 CONFIG_BT_NIMBLE_NVS_PERSIST=y
+# WATCH: NimBLE HOST allocations (GATT/mbufs/conn state, ~25-40 KB) go to PSRAM
+# instead of internal SRAM. The BLE controller stays internal (hard requirement).
+# NOTE: breaks BLE on any board built from these libs WITHOUT PSRAM.
+CONFIG_BT_NIMBLE_MEM_ALLOC_MODE_EXTERNAL=y
+CONFIG_SPIRAM_ALLOW_BSS_SEG_EXTERNAL_MEMORY=y
+CONFIG_SPIRAM_ALLOW_NOINIT_SEG_EXTERNAL_MEMORY=y
+CONFIG_SPIRAM_XIP_FROM_PSRAM=y
 CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
 CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
 CONFIG_SPIRAM=y
+CONFIG_SPIRAM_BANKSWITCH_ENABLE=y
+CONFIG_SPIRAM_BANKSWITCH_RESERVE=32
+# WATCH: do NOT set CONFIG_SPIRAM_SPEED_120M here. Flash and PSRAM share the MSPI
+# bus on the S3: 120 MHz PSRAM forces the 240 MHz core clock, which requires
+# 120 MHz flash too — that combination must come from defconfig.120m via a
+# builds.json tuple (e.g. qio/120m/opi_ram), never globally.
 CONFIG_RTC_CLK_CAL_CYCLES=576
 CONFIG_ESP32S3_UNIVERSAL_MAC_ADDRESSES_TWO=y
 # CONFIG_ESP_SLEEP_GPIO_RESET_WORKAROUND is not set
@@ -26,7 +39,7 @@ CONFIG_ULP_COPROC_RESERVE_MEM=512
 
 # RGB Display Optimizations
 # CONFIG_LCD_RGB_ISR_IRAM_SAFE is not set
-CONFIG_LCD_RGB_RESTART_IN_VSYNC=y
+CONFIG_LCD_RGB_RESTART_IN_VSYNC=n
 
 # Matter settings:
 CONFIG_ENABLE_CHIPOBLE=y
@@ -37,7 +50,10 @@ CONFIG_ENABLE_CHIPOBLE=y
 # Enables a free TX-buffer choice, removes the internal cache-TX pool
 # (~25 KB wasted when PSRAM is off), and drops RX_BA_WIN back to its lean default
 # We then re-assert a STATIC TX pool for TX reliability.
-CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=n
+# WATCH: upstream sets this =n for PSRAM-less Matter boards; we always have PSRAM,
+# and =y is what the stock 3.3.8 release libs shipped with (WiFi/LWIP dynamic
+# buffers go to PSRAM). Keep =y.
+CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
 
 # Keep STATIC TX buffers (robust under bursty UDP/TCP load), modest count
 CONFIG_ESP_WIFI_STATIC_TX_BUFFER=y
@@ -54,3 +70,20 @@ CONFIG_ESP_WIFI_RX_BA_WIN=8
 CONFIG_USB_HOST_HUBS_SUPPORTED=y
 CONFIG_USB_HOST_HUB_MULTI_LEVEL=y
 CONFIG_USB_HOST_HW_BUFFER_BIAS_PERIODIC_OUT=y
+
+# --- WATCH customizations (ESP32-S3-WatchFace custom core) ---
+# Allow FreeRTOS task stacks in PSRAM. Opt-in per task via
+# xTaskCreatePinnedToCoreWithCaps(..., MALLOC_CAP_SPIRAM); a task with a PSRAM
+# stack must never touch flash while the cache is disabled (no NVS writes/OTA).
+CONFIG_FREERTOS_TASK_CREATE_ALLOW_EXT_MEM=y
+# Build the IDF libs (lwip, wifi, mbedtls, ...) -O2 instead of -Os: speed over
+# size — the watch has 32 MB flash. Overrides the SIZE=y from defconfig.common
+# (this file is applied after it).
+CONFIG_COMPILER_OPTIMIZATION_SIZE=n
+CONFIG_COMPILER_OPTIMIZATION_PERF=y
+# REAL per-core CPU usage for the Power app: FreeRTOS timestamps every context
+# switch (esp_timer clock, 1 us resolution) and accumulates true run time per
+# task; the idle tasks' runtime then gives measured busy %, replacing the
+# idle-tick proxy. cpu_usage.h auto-detects this flag and switches paths.
+# Cost: one timer read per context switch — negligible.
+CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y
